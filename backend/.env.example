# Server
PORT=3000
NODE_ENV=development

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:8080,http://127.0.0.1:8080
# Railway alias (single origin): CORS_URL=https://your-frontend.netlify.app

# Public base URL of this backend (used to generate image URLs)
# Local: http://localhost:3000
# Railway: https://<your-service>.up.railway.app
PUBLIC_BASE_URL=http://localhost:3000
# Railway alias: APP_URL=https://<your-service>.up.railway.app

# Database (Supabase Postgres)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres
DATABASE_SSL=true
# Railway alias: DB_SSL=true

# JWT
JWT_SECRET=change-me
# Railway alias: JWT_SECRET_PASSWORD=change-me
JWT_EXPIRES_IN=1h

# Uploads (filesystem)
# On Railway: mount a Volume and set UPLOADS_DIR to that mount path.
UPLOADS_DIR=uploads

# Gemini
GEMINI_API_KEY=YOUR_GEMINI_KEY
DEFAULT_CURRENCY=USD

# Upload limits
MAX_IMAGE_COUNT=10
MAX_IMAGE_SIZE_BYTES=5242880
